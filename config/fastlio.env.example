ROS_SETUP_BASH=/opt/ros/humble/setup.bash
LOCALIZATION_WS_ROOT=/tmp/sunray_slam_ws
LOCALIZATION_WS_SETUP_BASH=${LOCALIZATION_WS_ROOT}/install/setup.bash
SUNRAY_RUN_DIR=${SUNRAY_SLAM_ROOT}/.runtime/slam/run
SUNRAY_LOG_DIR=${SUNRAY_SLAM_ROOT}/.runtime/slam/logs
ROS_DOMAIN_ID=0

LIVOX_HOST_IFACE=eth0
LIVOX_HOST_IP=192.168.1.5
LIVOX_SETTLE_SEC=3
LIVOX_TOPIC_WAIT_TIMEOUT_SEC=300
STARTUP_TIMING_FILE=${SUNRAY_RUN_DIR}/startup_timing.log
